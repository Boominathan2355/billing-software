# Server Environment Variables Example

# Port for the Express server (default 5000)
PORT=5000

# MongoDB Connection URI
# Local: mongodb://localhost:27017/billing_erp
# Production: mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname

# JWT Secret for authentication
JWT_SECRET=your_super_secret_jwt_random_string_here

# Node Environment (development or production)
NODE_ENV=development
